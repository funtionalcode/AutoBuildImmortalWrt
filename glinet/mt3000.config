# GL-MT3000 ImmortalWrt 编译配置（精简版）
# 设备：GL.iNet GL-MT3000 (MT7981 / mediatek/filogic)
# 参考 ufi103s_v01.config，适配路由器平台

# ==========================================
# 基础系统（必须显式启用，defconfig 不自动拉取）
# ==========================================
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_uhttpd=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_rpcd=y
CONFIG_PACKAGE_rpcd-mod-luci=y

# ==========================================
# 目标平台
# ==========================================
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_glinet_gl-mt3000=y

# ==========================================
# 镜像格式
# ==========================================
CONFIG_TARGET_ROOTFS_EXT4FS=y
CONFIG_TARGET_EXT4_JOURNAL=y
CONFIG_TARGET_IMAGES_GZIP=y

# ==========================================
# WiFi（MT7981 内置 WiFi，默认驱动已包含）
# 无需额外 WiFi 驱动包（区别于 103s 的 WCN36xx）
# ==========================================
CONFIG_PACKAGE_wpad-basic-openssl=y
CONFIG_PACKAGE_iw=y
CONFIG_PACKAGE_iwinfo=y
CONFIG_PACKAGE_wifi-scripts=y
CONFIG_PACKAGE_wireless-regdb=y

# ==========================================
# 防火墙
# ==========================================
CONFIG_PACKAGE_luci-app-firewall=y

# ==========================================
# FRP 内网穿透 + WireGuard 组网
# ==========================================
CONFIG_PACKAGE_luci-app-frpc=y
CONFIG_PACKAGE_wireguard-tools=y
CONFIG_PACKAGE_luci-proto-wireguard=y
CONFIG_PACKAGE_kmod-wireguard=y

# ==========================================
# 住宅代理（Nikki - Mihomo 内核）
# ==========================================
CONFIG_PACKAGE_luci-app-nikki=y
CONFIG_PACKAGE_mihomo-meta=y
# CONFIG_PACKAGE_mihomo-alpha is not set
CONFIG_PACKAGE_kmod-nft-tproxy=y
CONFIG_PACKAGE_kmod-nft-nat=y

# ==========================================
# Socat 端口转发
# ==========================================
CONFIG_PACKAGE_luci-app-socat=y

# ==========================================
# 终端工具
# ==========================================
CONFIG_PACKAGE_luci-app-ttyd=y

# ==========================================
# WiFi 中继
# ==========================================
CONFIG_PACKAGE_luci-proto-relay=y

# ==========================================
# 可选：取消注释启用
# ==========================================
# CONFIG_PACKAGE_luci-app-netdata=y     # 系统监控
# CONFIG_PACKAGE_luci-app-nlbwmon=y     # 流量监控
# CONFIG_PACKAGE_luci-app-upnp=y        # UPnP 端口映射
# CONFIG_PACKAGE_luci-app-ddns=y        # 动态DNS
# CONFIG_PACKAGE_luci-app-samba4=y      # Samba 文件共享
# CONFIG_PACKAGE_luci-i18n-samba4-zh-cn=y  # Samba 中文
# CONFIG_PACKAGE_luci-app-zerotier=y   # ZeroTier 组网
# CONFIG_PACKAGE_luci-i18n-zerotier-zh-cn=y  # ZeroTier 中文